# Neon PostgreSQL
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# Google OAuth (with Gmail scopes)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Anthropic (claude-haiku-4-5)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Pusher
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# Upstash Redis (for BullMQ)
UPSTASH_REDIS_URL="rediss://default:xxx@xxx.upstash.io:6380"
UPSTASH_REDIS_TOKEN="your-upstash-token"

# Hunter.io (email finder)
HUNTER_API_KEY="your-hunter-api-key"

# Resend (notification emails only)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="notifications@yourdomain.com"

# Adzuna (job aggregation)
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_API_KEY="your-adzuna-api-key"

# The Muse (job aggregation - no key required)
# Remotive (job aggregation - no key required)
# Arbeitnow (job aggregation - no key required)

# Token Encryption (must be exactly 32 characters)
TOKEN_ENCRYPTION_KEY="your-32-char-encryption-key-here"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
