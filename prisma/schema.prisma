generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  image              String?
  onboardingComplete Boolean   @default(false)
  gmailAddress       String?
  gmailAccessToken   String?   // encrypted
  gmailRefreshToken  String?   // encrypted
  gmailTokenExpiry   DateTime?
  resumeUrl          String?
  resumeCloudinaryId String?
  resumeText         String?
  targetRole         String?
  targetCompanies    String[]  @default([])
  skills             String[]  @default([])
  dailySendLimit     Int       @default(20)
  warmupPhase        Int       @default(1)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  jobs      Job[]
  emails    EmailSent[]
  sequences Sequence[]
  offers    Offer[]
  warmupLogs WarmupLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Job {
  id              String   @id @default(cuid())
  userId          String
  title           String
  company         String
  location        String?
  description     String?  @db.Text
  url             String?
  source          String?
  salary          String?
  jobType         String?
  skills          String[] @default([])
  matchScore      Int?
  skillsGap       String[] @default([])
  companyEmail    String?
  emailConfidence String?
  status          String   @default("discovered")
  notes           String?  @db.Text
  appliedAt       DateTime?
  followUpAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails    EmailSent[]
  sequences Sequence[]

  @@map("jobs")
}

model EmailSent {
  id          String    @id @default(cuid())
  userId      String
  jobId       String?
  sequenceId  String?
  to          String
  subject     String
  body        String    @db.Text
  gmailMsgId  String?
  threadId    String?
  pixelId     String    @unique @default(cuid())
  openedAt    DateTime?
  repliedAt   DateTime?
  sentAt      DateTime  @default(now())
  isWarmup    Boolean   @default(false)
  sentiment   String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job      Job?      @relation(fields: [jobId], references: [id])
  sequence Sequence? @relation(fields: [sequenceId], references: [id])

  @@map("emails_sent")
}

model Sequence {
  id          String    @id @default(cuid())
  userId      String
  jobId       String?
  name        String
  steps       Json      @default("[]")
  status      String    @default("active")
  currentStep Int       @default(0)
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job?        @relation(fields: [jobId], references: [id])
  emails EmailSent[]

  @@map("sequences")
}

model Offer {
  id           String   @id @default(cuid())
  userId       String
  company      String
  role         String
  salary       Float?
  equity       String?
  benefits     String[] @default([])
  deadline     DateTime?
  notes        String?  @db.Text
  status       String   @default("pending")
  aiAnalysis   String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("offers")
}

model WarmupLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  emailsSent Int     @default(0)
  phase     Int      @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("warmup_logs")
}
