{
  "compilerOptions": {
    "lib": ["es2020"],
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/workers",
    "paths": { "@/*": ["./*"] }
  },
  "include": ["workers/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules"]
}
